# Copie para .env e preencha os valores

# Chave obrigatória — gere com: openssl rand -hex 32
JWT_SECRET=SUBSTITUA_COM_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=SUBSTITUA_COM_OPENSSL_RAND_HEX_32
CREDS_KEY=SUBSTITUA_COM_OPENSSL_RAND_HEX_32
CREDS_IV=SUBSTITUA_COM_OPENSSL_RAND_HEX_16

# LLM — use o mesmo GEMINI_API_KEY do backend
GEMINI_API_KEY=sua_chave_aqui

# Opcional — desabilita telemetria
TELEMETRY_ENABLED=false
