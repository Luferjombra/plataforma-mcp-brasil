# Copie para .env e preencha os valores
#
# Gerar segredos no PowerShell (Node.js necessário):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  -> JWT_SECRET, JWT_REFRESH_SECRET, CREDS_KEY
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"  -> CREDS_IV

# Segredos obrigatórios
JWT_SECRET=cole_aqui_64_chars_hex
JWT_REFRESH_SECRET=cole_aqui_64_chars_hex
CREDS_KEY=cole_aqui_64_chars_hex
CREDS_IV=cole_aqui_32_chars_hex

# ── LLMs (pelo menos 1 obrigatório) ───────────────────────────────────────
# DeepSeek — 5M tokens grátis, sem cartão: platform.deepseek.com
DEEPSEEK_API_KEY=

# Groq — 14.400 req/dia grátis: console.groq.com
GROQ_API_KEY=

# Cerebras — 1M tokens/dia grátis: cloud.cerebras.ai
CEREBRAS_API_KEY=

# GLM/Zhipu — grátis para sempre, 203K ctx: open.bigmodel.cn
GLM_API_KEY=

# Desabilita telemetria
TELEMETRY_ENABLED=false
