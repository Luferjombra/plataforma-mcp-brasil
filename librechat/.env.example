# Copie para .env e preencha os valores
#
# Para gerar os segredos no PowerShell (Node.js necessário):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  -> para as 3 primeiras
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"  -> para CREDS_IV

# Segredos obrigatórios
JWT_SECRET=cole_aqui_64_chars_hex
JWT_REFRESH_SECRET=cole_aqui_64_chars_hex
CREDS_KEY=cole_aqui_64_chars_hex
CREDS_IV=cole_aqui_32_chars_hex

# LLM — use o mesmo GEMINI_API_KEY do projeto
GEMINI_API_KEY=sua_chave_aqui

# Desabilita telemetria
TELEMETRY_ENABLED=false
